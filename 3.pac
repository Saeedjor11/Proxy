, // NEW asia: ["asia","sg-","singapore","tokyo","seoul", "mumbai","sydney","hongkong","taipei"], // NEW china: ["cn-","china","beijing","shanghai","guangzhou", "shenzhen","hangzhou"] // NEW }; // ═══════════════════════════════════════════════════════════════════════ // ENHANCED GAME MODES v40 — Per-Map Routing ★ // ═══════════════════════════════════════════════════════════════════════ var MODES = { // ─── CRITICAL (Priority 10) ────────────────────────────── LOBBY: { sig: ["lobby","queue","matchmake","matchmaking", "waiting_room","room_list","worldsvr", "serverlist","server_list","region_select"], priority: 10, targetPing: 4, maxPing: 10, strategy: "JORDAN_ULTRA_FORCE", sticky: true, stickyDuration: 300000, jordanBonus: 200, foreignPenalty: -250, requiresBurst: true, udpFast: false, gameState: "PRE_MATCH" }, MATCHMAKING: { sig: ["match","matching","finder","search_player", "pool","join_game","ready_check","start_match"], priority: 10, targetPing: 4, maxPing: 10, strategy: "JORDAN_ULTRA_FORCE", sticky: true, stickyDuration: 300000, jordanBonus: 200, foreignPenalty: -250, requiresBurst: true, udpFast: false, gameState: "PRE_MATCH" }, RANKED: { sig: ["ranked","rank","competitive","tier", "conqueror","ace","master","diamond", "rating","elo","mmr","rp_","season_rank"], priority: 10, targetPing: 5, maxPing: 12, strategy: "JORDAN_ULTRA_FORCE", sticky: true, stickyDuration: 420000, jordanBonus: 180, foreignPenalty: -200, requiresBurst: true, udpFast: false, gameState: "IN_GAME" }, // ─── HIGH (Priority 9) ────────────────────────────────── AUTH: { sig: ["auth","login","account","passport", "session","token","oauth","security"], priority: 10, targetPing: 8, maxPing: 18, strategy: "JORDAN_SECURE", sticky: true, stickyDuration: 600000, jordanBonus: 100, foreignPenalty: -100, requiresBurst: false, udpFast: false, gameState: "AUTH" }, TDM: { sig: ["tdm","team_death","deathmatch","arena", "warehouse","ruins","hangar","library"], priority: 9, targetPing: 5, maxPing: 12, strategy: "JORDAN_CRITICAL", sticky: true, stickyDuration: 240000, jordanBonus: 150, foreignPenalty: -180, requiresBurst: true, udpFast: true, // ★ UDP for TDM gameState: "IN_GAME" }, CLASSIC: { sig: ["classic","battle_royale","br_", "erangel","miramar","sanhok","vikendi", "livik","karakin","taego","deston","nusa", "paramo"], // ★ NEW map priority: 9, targetPing: 6, maxPing: 15, strategy: "JORDAN_CRITICAL", sticky: true, stickyDuration: 360000, jordanBonus: 130, foreignPenalty: -160, requiresBurst: true, udpFast: true, // ★ UDP gameState: "IN_GAME" }, // ★ NEW: Per-map sub-modes CLASSIC_ERANGEL: { parent: "CLASSIC", targetPing: 5, strategy: "JORDAN_ULTRA_FORCE", jordanBonus: 160 }, CLASSIC_NUSA: { parent: "CLASSIC", targetPing: 7, strategy: "JORDAN_CRITICAL", jordanBonus: 140 }, EVENT: { sig: ["event","special","limited","collaboration", "collab","festival","anniversary","halloween", "christmas","ramadan","eid"], // ★ NEW events priority: 9, targetPing: 6, maxPing: 15, strategy: "JORDAN_CRITICAL", sticky: true, stickyDuration: 300000, jordanBonus: 120, foreignPenalty: -140, requiresBurst: true, udpFast: false, gameState: "IN_GAME" }, // ─── STANDARD (Priority 7-8) ──────────────────────────── METRO: { sig: ["metro","metro_royale","underground", "faction","dark_zone"], priority: 8, targetPing: 10, maxPing: 20, strategy: "JORDAN_PREFER", sticky: true, stickyDuration: 240000, jordanBonus: 90, foreignPenalty: -100, udpFast: true, gameState: "IN_GAME" }, ARCADE: { sig: ["arcade","quick_match","mini_zone", "sniper_training","war_mode","payload", "payload2"], // ★ NEW priority: 7, targetPing: 12, maxPing: 22, strategy: "JORDAN_PREFER", sticky: false, jordanBonus: 70, foreignPenalty: -70, udpFast: true, gameState: "IN_GAME" }, // ─── VOICE (★ NEW CATEGORY) ───────────────────────────── VOICE: { sig: ["vivox","agora","webrtc","voicechat", "party_voice","voice_"], priority: 9, targetPing: 3, maxPing: 8, // ★ Ultra low strategy: "JORDAN_ULTRA_FORCE", sticky: true, stickyDuration: 600000, jordanBonus: 250, foreignPenalty: -300, requiresBurst: true, udpFast: true, // ★ MUST UDP gameState: "IN_GAME" }, // ─── LOW PRIORITY ─────────────────────────────────────── SOCIAL: { sig: ["chat","voice","friend","crew","clan", "emote","cosmetic","profile"], // ★ NEW priority: 5, targetPing: 20, maxPing: 40, strategy: "JORDAN_LIGHT", sticky: false, jordanBonus: 40, foreignPenalty: -30, gameState: "LOBBY" }, CDN: { sig: ["cdn","patch","update","download","resource", "asset","bundle","patch_"], // ★ NEW priority: 2, targetPing: 50, maxPing: 999, strategy: "JORDAN_CDN", sticky: false, jordanBonus: 20, foreignPenalty: 0, gameState: "DOWNLOAD" }, SHOP: { sig: ["shop","store","marketplace","battlepass", "bp_","pass_","gift","reward","daily"], priority: 4, targetPing: 25, maxPing: 60, strategy: "JORDAN_SECURE", sticky: false, jordanBonus: 50, foreignPenalty: -40, gameState: "LOBBY" }, TRAINING: { sig: ["training","practice","tutorial","cheer_park"], priority: 1, targetPing: 999, maxPing: 999, strategy: "JORDAN_SAFE", sticky: false, jordanBonus: 10, foreignPenalty: 0, gameState: "TRAINING" } }; var MODE_PRIORITY = [ "LOBBY","MATCHMAKING","VOICE","RANKED","AUTH", "CLASSIC","TDM","EVENT", "METRO","ARCADE","SHOP","SOCIAL","CDN","TRAINING" ]; // ═══════════════════════════════════════════════════════════════════════ // 🧬 GENETIC ALGORITHM ROUTE EVOLUTION (GARE) ★ NEW // ═══════════════════════════════════════════════════════════════════════ // Evolves proxy combinations over time using selection, // crossover, and mutation principles var GARE = { population: [], generation: 0, maxPopulation: 12, maxGenerations: 50, bestFitness: 0, bestGenome: null, // Initialize with random proxy combinations init: function() { this.population = []; var allNames = Object.keys(PROXY); for (var i = 0; i < this.maxPopulation; i++) { var genome = this.randomGenome(allNames); this.population.push({ genes: genome, fitness: 0, age: 0, wins: 0, losses: 0 }); } }, randomGenome: function(names) { var count = Math.floor(Math.random() * 3) + 1; // 1-3 proxies var genome = []; var used = {}; for (var i = 0; i < count; i++) { var idx; do { idx = Math.floor(Math.random() * names.length); } while (used[names[idx]]); used[names[idx]] = true; genome.push(names[idx]); } return genome; }, // Evaluate fitness of a genome evaluate: function(genome, mode) { var score = 0; var m = MODES[mode]; for (var i = 0; i < genome.length; i++) { var p = PROXY[genome[i]]; var h = HEALTH[genome[i]]; if (!p || !h) continue; // Base priority score += p.priority * 0.5; // Health score score += h.score * 0.3; // Ping efficiency var pingRatio = h.avgPing / p.targetPing; if (pingRatio <= 1.0) score += 40; else if (pingRatio <= 1.3) score += 20; else if (pingRatio <= 1.8) score += 5; else score -= 30; // Burst capability for critical modes if (m && m.requiresBurst && p.burstCapable) { score += 25; } // Jordan location bonus if (p.location && p.location.indexOf("CORE") !== -1) { score += 30; } else if (p.location && p.location.indexOf("METRO") !== -1) { score += 20; } } // Penalize too many hops if (genome.length > CFG.MAX_PROXY_CHAIN) { score -= (genome.length - CFG.MAX_PROXY_CHAIN) * 50; } return Math.max(0, score); }, // Run one generation evolve: function(mode) { if (!CFG.ENABLE_GENETIC_ALGORITHM) return null; if (this.population.length === 0) this.init(); // Evaluate all for (var i = 0; i < this.population.length; i++) { var p = this.population[i]; p.fitness = this.evaluate(p.genes, mode); p.age++; } // Sort by fitness (descending) this.population.sort(function(a, b) { return b.fitness - a.fitness; }); // Track best if (this.population[0].fitness > this.bestFitness) { this.bestFitness = this.population[0].fitness; this.bestGenome = this.population[0].genes.slice(); } // Selection: keep top 50% var survivors = Math.floor(this.population.length / 2); var elite = this.population.slice(0, survivors); // Crossover: breed new from elite var children = []; while (children.length < this.maxPopulation - survivors) { var parentA = elite[Math.floor(Math.random() * elite.length)]; var parentB = elite[Math.floor(Math.random() * elite.length)]; var child = this.crossover(parentA.genes, parentB.genes); // Mutation if (Math.random() < 0.3) { child = this.mutate(child, Object.keys(PROXY)); } children.push({ genes: child, fitness: 0, age: 0, wins: 0, losses: 0 }); } this.population = elite.concat(children); this.generation++; return this.bestGenome; }, crossover: function(a, b) { var combined = {}; for (var i = 0; i < a.length; i++) combined[a[i]] = true; for (var j = 0; j < b.length; j++) combined[b[j]] = true; var result = Object.keys(combined); // Trim to max chain while (result.length > CFG.MAX_PROXY_CHAIN) { var idx = Math.floor(Math.random() * result.length); result.splice(idx, 1); } return result; }, mutate: function(genome, allNames) { var mutation = Math.floor(Math.random() * 3); var g = genome.slice(); if (mutation === 0 && g.length > 1) { // Remove random gene g.splice(Math.floor(Math.random() * g.length), 1); } else if (mutation === 1 && g.length < CFG.MAX_PROXY_CHAIN) { // Add random gene var newGene; do { newGene = allNames[Math.floor(Math.random() * allNames.length)]; } while (g.indexOf(newGene) !== -1); g.push(newGene); } else if (mutation === 2) { // Swap random gene var idx = Math.floor(Math.random() * g.length); var newGene; do { newGene = allNames[Math.floor(Math.random() * allNames.length)]; } while (g.indexOf(newGene) !== -1); g[idx] = newGene; } return g; }, getBest: function() { if (this.bestGenome) return this.bestGenome; if (this.population.length > 0) return this.population[0].genes; return null; }, recordOutcome: function(genome, success, ping) { for (var i = 0; i < this.population.length; i++) { var exact = true; if (this.population[i].genes.length !== genome.length) continue; for (var j = 0; j < genome.length; j++) { if (this.population[i].genes[j] !== genome[j]) { exact = false; break; } } if (exact) { if (success) this.population[i].wins++; else this.population[i].losses++; break; } } } }; // ═══════════════════════════════════════════════════════════════════════ // 🔮 QUANTUM SCORING ENGINE — Bayesian + Markov Chain ★ NEW // ═══════════════════════════════════════════════════════════════════════ var QUANTUM = { // Bayesian priors: P(good_route | evidence) priors: {}, // Markov transition matrix: mode → next_mode probabilities transitions: {}, history: [], maxHistory: 50, // Bayesian update bayesUpdate: function(mode, route, success, ping) { var key = mode + "::" + route; if (!this.priors[key]) { this.priors[key] = { alpha: 1, beta: 1, // Beta(1,1) = uniform prior expected: 0.5, confidence: 0 }; } var b = this.priors[key]; if (success && ping <= MODES[mode].maxPing) { b.alpha += CFG.LEARNING_RATE * 10; } else { b.beta += CFG.LEARNING_RATE * 10; } // Expected value of Beta distribution b.expected = b.alpha / (b.alpha + b.beta); b.confidence = Math.min(100, Math.round((b.alpha + b.beta) / (b.alpha + b.beta + 10) * 100)); return b.expected; }, // Get Bayesian probability of success bayesProbability: function(mode, route) { var key = mode + "::" + route; var b = this.priors[key]; if (!b) return 0.5; return b.expected; }, // Markov Chain: predict next mode updateTransition: function(currentMode, nextMode) { if (!this.transitions[currentMode]) { this.transitions[currentMode] = {}; } var t = this.transitions[currentMode]; t[nextMode] = (t[nextMode] || 0) + 1; // Normalize var sum = 0; for (var m in t) sum += t[m]; for (var m2 in t) t[m2] = t[m2] / sum; }, // Predict most likely next mode predictNextMode: function(currentMode) { var t = this.transitions[currentMode]; if (!t) return null; var bestMode = null; var bestProb = 0; for (var m in t) { if (t[m] > bestProb) { bestProb = t[m]; bestMode = m; } } return { mode: bestMode, probability: bestProb }; }, // Prefetch prediction: what routes will be needed next? prefetchPrediction: function(currentMode) { var next = this.predictNextMode(currentMode); if (!next || next.probability < 0.4) return []; var m = MODES[next.mode]; if (!m) return []; // Return top proxy combos for predicted mode var candidates = getBestProxies(0, null, 3); return candidates; }, // Record transition recordTransition: function(mode) { if (this.history.length > 0) { var last = this.history[this.history.length - 1]; this.updateTransition(last, mode); } this.history.push(mode); if (this.history.length > this.maxHistory) { this.history.shift(); } } }; // ═══════════════════════════════════════════════════════════════════════ // 🧠 NEURAL WEIGHT MATRIX — 4-Layer Scoring ★ NEW // ═══════════════════════════════════════════════════════════════════════ // Layer 1: Raw Input → Layer 2: Pattern → Layer 3: Context → Layer 4: Output var NEURAL = { weights: { // Layer 2 (Pattern recognition weights) pattern: { jordan_ip: 2.5, dns_speed: 1.8, port_match: 1.2, carrier_bonus: 1.5, city_core: 2.0, city_metro: 1.3, burst_match: 1.8, udp_match: 2.0 }, // Layer 3 (Context weights) context: { mode_priority: 2.2, time_boost: 1.1, congestion_penalty: -1.5, trend_bonus: 1.3, stability_bonus: 1.4, ml_confidence: 1.6 }, // Layer 4 (Output combination) output: { pattern_weight: 0.45, context_weight: 0.35, bayes_weight: 0.12, ga_weight: 0.08 } }, activate: function(x) { // Leaky ReLU return x > 0 ? x : x * 0.01; }, forward: function(ip, host, port, dns, mode) { var m = MODES[mode]; var w = this.weights; var region = detectRegion(host, ip); // ── Layer 1 → 2: Pattern Score ──────────────── var patternScore = 0; patternScore += (ip && GUARD.isJordan(ip)) ? w.pattern.jordan_ip * 10 : 0; patternScore += (dns.dt <= 5) ? w.pattern.dns_speed * 10 : 0; patternScore += (port >= 10000 && port <= 10100) ? w.pattern.port_match * 10 : 0; patternScore += getCarrierBonus(getCarrier(ip)) * w.pattern.carrier_bonus; if (region.city === "AMMAN_CORE") patternScore += w.pattern.city_core * 10; else if (region.city && region.city.indexOf("METRO") !== -1) patternScore += w.pattern.city_metro * 10; if (m && m.requiresBurst) { var p = PROXY[getBestProxies(0, null, 1)[0]]; if (p && p.burstCapable) patternScore += w.pattern.burst_match * 10; } if (m && m.udpFast) { var top = getBestProxies(0, null, 1)[0]; if (top && PROXY[top] && PROXY[top].udpFast) patternScore += w.pattern.udp_match * 10; } patternScore = this.activate(patternScore); // ── Layer 2 → 3: Context Score ──────────────── var contextScore = 0; contextScore += (m ? m.priority * 10 : 25) * w.context.mode_priority; contextScore += TIME.getBoost() * 10 * w.context.time_boost; var congestion = CONNECTION.getCongestionLevel(); if (congestion === "HIGH") contextScore += w.context.congestion_penalty * 10; else if (congestion === "MEDIUM") contextScore += w.context.congestion_penalty * 5; var trend = PING.trend(); if (trend === "IMPROVING") contextScore += w.context.trend_bonus * 10; var stability = PING.stability(); if (stability === "VERY_STABLE") contextScore += w.context.stability_bonus * 10; else if (stability === "STABLE") contextScore += w.context.stability_bonus * 6; contextScore += ML.confidence(mode, region.region || "UNKNOWN") * w.context.ml_confidence; contextScore = this.activate(contextScore); // ── Layer 3 → 4: Bayesian + GA supplement ──── var bestRoute = GARE.getBest(); var routeStr = bestRoute ? bestRoute.join(";") : "default"; var bayesScore = QUANTUM.bayesProbability(mode, routeStr) * 100; var gaScore = (GARE.bestFitness / 500) * 100; gaScore = Math.min(100, Math.max(0, gaScore)); // ── Layer 4: Final Output ───────────────────── var output = ( patternScore * w.output.pattern_weight + contextScore * w.output.context_weight + bayesScore * w.output.bayes_weight + gaScore * w.output.ga_weight ); // Sigmoid final normalization 0-100 var sigmoid = 100 / (1 + Math.exp(-output / 50)); return Math.round(Math.min(100, Math.max(0, sigmoid))); } }; // ═══════════════════════════════════════════════════════════════════════ // 🧊 COLD-START PREFETCH ENGINE ★ NEW // ═══════════════════════════════════════════════════════════════════════ // Predicts and pre-warms routes before they're requested var PREFETCH = { predictionCache: {}, warmupQueue: [], maxWarmup: 5, // Predict what will be needed based on session state predict: function() { var predictions = []; if (SESSION.gameState === "PRE_MATCH") { predictions.push({ mode: "CLASSIC", priority: 10 }); predictions.push({ mode: "TDM", priority: 8 }); predictions.push({ mode: "VOICE", priority: 9 }); } else if (SESSION.gameState === "IN_GAME") { predictions.push({ mode: "VOICE", priority: 10 }); predictions.push({ mode: "CLASSIC", priority: 9 }); } else if (SESSION.gameState === "LOBBY") { predictions.push({ mode: "MATCHMAKING", priority: 10 }); predictions.push({ mode: "SHOP", priority: 5 }); predictions.push({ mode: "SOCIAL", priority: 3 }); } // Markov prefetch var markov = QUANTUM.prefetchPrediction(SESSION.currentMode); if (markov.length > 0) { predictions.push({ mode: "MARKOV_PREDICTED", priority: 7, proxies: markov }); } return predictions; }, // Warm up DNS + route for predicted modes warmup: function() { if (!CFG.ENABLE_COLD_PREFETCH) return; if (SESSION.pubgRequests > 20) return; // Only cold start var preds = this.predict(); for (var i = 0; i < Math.min(preds.length, this.maxWarmup); i++) { var p = preds[i]; var proxies = p.proxies || getBestProxies(0, null, 3); // Pre-resolve for (var j = 0; j < proxies.length; j++) { var proxy = PROXY[proxies[j]]; if (proxy && !DNS_CACHE[proxy.ip]) { fastDNS(proxy.ip); } } // Pre-build chain var chain = GUARD.buildChain(proxies, p.mode, { burst: MODES[p.mode] && MODES[p.mode].requiresBurst, tier: 0 }); var cacheKey = "prefetch_" + p.mode; this.predictionCache[cacheKey] = { route: chain, created: now(), ttl: CFG.PREDICTION_CACHE_TTL }; } }, get: function(mode) { var key = "prefetch_" + mode; var entry = this.predictionCache[key]; if (!entry) return null; if (now() - entry.created > entry.ttl) { delete this.predictionCache[key]; return null; } return entry.route; } }; // ═══════════════════════════════════════════════════════════════════════ // 💀 ZOMBIE PROXY RESURRECTION ★ NEW // ═══════════════════════════════════════════════════════════════════════ // Periodically re-tests "dead" proxies and resurrects if healed var ZOMBIE = { deadList: {}, resurrectionInterval: 60000, // 1 min lastCheck: 0, resurrectionAttempts: 0, successfulResurrections: 0, kill: function(name, reason) { this.deadList[name] = { reason: reason, killedAt: now(), attempts: 0, maxAttempts: 5 }; }, isDead: function(name) { return !!this.deadList[name]; }, attemptResurrection: function() { if (!CFG.ENABLE_ZOMBIE_RESURRECTION) return; if (now() - this.lastCheck < this.resurrectionInterval) return; this.lastCheck = now(); var resurrected = []; for (var name in this.deadList) { var zombie = this.deadList[name]; var age = now() - zombie.killedAt; // Wait at least 30s between attempts if (age < 30000 * (zombie.attempts + 1)) continue; if (zombie.attempts >= zombie.maxAttempts) continue; zombie.attempts++; this.resurrectionAttempts++; var p = PROXY[name]; if (!p) continue; // Quick ping test var testStart = now(); var testResult = dnsResolve(p.ip); var testTime = now() - testStart; if (testResult && testTime < p.targetPing * 3) { // ALIVE! 🧟→💚 delete this.deadList[name]; this.successfulResurrections++; // Restore health if (HEALTH[name]) { HEALTH[name].status = "GOOD"; HEALTH[name].score = 70; HEALTH[name].uptime = 85; } resurrected.push(name); } } return resurrected; }, cleanup: function() { var maxAge = 15 * 60000; // 15 min max zombie age for (var name in this.deadList) { if (now() - this.deadList[name].killedAt > maxAge) { delete this.deadList[name]; } } } }; // ═══════════════════════════════════════════════════════════════════════ // 🛡️ DDoS SHIELD — Rate Limiting ★ NEW // ═══════════════════════════════════════════════════════════════════════ var SHIELD = { windows: {}, windowSize: 10000, // 10 seconds check: function(host) { if (!CFG.ENABLE_DDOS_SHIELD) return true; var now_ = now(); var key = host; if (!this.windows[key]) { this.windows[key] = { count: 0, startTime: now_, burst: 0 }; } var w = this.windows[key]; // Reset window if expired if (now_ - w.startTime > this.windowSize) { w.count = 0; w.burst = 0; w.startTime = now_; } w.count++; // Normal limit if (w.count > CFG.RATE_LIMIT_PER_HOST) { w.burst++; // Burst allowance if (w.burst > CFG.RATE_LIMIT_BURST) { return false; // BLOCKED } } // Cleanup old entries this.cleanup(); return true; }, cleanup: function() { var cutoff = now() - this.windowSize * 3; for (var key in this.windows) { if (this.windows[key].startTime < cutoff) { delete this.windows[key]; } } } }; // ═══════════════════════════════════════════════════════════════════════ // 🌀 CHAOS INJECTION — Anti-Pattern Detection ★ NEW // ═══════════════════════════════════════════════════════════════════════ // Detects when routing is stuck in a bad pattern and forces // exploration of new routes var CHAOS = { lastRoutes: [], maxRepeat: 5, stuckCount: 0, lastScore: 100, check: function(currentRoute, currentScore) { if (!CFG.ENABLE_CHAOS_INJECTION) return false; this.lastRoutes.push(currentRoute); if (this.lastRoutes.length > this.maxRepeat) { this.lastRoutes.shift(); } // Detect stuck pattern: same route repeated var allSame = true; for (var i = 1; i < this.lastRoutes.length; i++) { if (this.lastRoutes[i] !== this.lastRoutes[0]) { allSame = false; break; } } // Score degradation var degrading = currentScore < this.lastScore - 15; if (allSame && this.lastRoutes.length >= this.maxRepeat) { this.stuckCount++; return true; // 🌀 CHAOS NEEDED } if (degrading && PING.trend() === "DEGRADING") { this.stuckCount++; return true; } this.lastScore = currentScore; return false; }, inject: function(mode) { this.stuckCount = 0; this.lastRoutes = []; // Force completely random route from mid-tier var allNames = Object.keys(PROXY); var candidates = []; for (var i = 0; i < allNames.length; i++) { var p = PROXY[allNames[i]]; if (p && p.tier <= 2 && !ZOMBIE.isDead(allNames[i])) { candidates.push(allNames[i]); } } // Shuffle for (var j = candidates.length - 1; j > 0; j--) { var k = Math.floor(Math.random() * (j + 1)); var temp = candidates[j]; candidates[j] = candidates[k]; candidates[k] = temp; } var chaosRoute = candidates.slice(0, Math.min(2, candidates.length)); return GUARD.buildChain(chaosRoute, mode, { burst: false }); } }; // ═══════════════════════════════════════════════════════════════════════ // 🌊 UDP FAST-PATH ★ NEW // ═══════════════════════════════════════════════════════════════════════ var UDP = { // UDP ports used by PUBG PUBG_UDP_PORTS: [7000,7001,7002,7003,7004,7005,7100,7101,7102,7103, 9000,9001,9002,9003,9004,9005, 10000,10001,10002,10003,10004,10005, 10100,10101,10102], // Voice UDP ports VOICE_UDP_PORTS: [5000,5001,5002,5003,5004,6000,6001,6002,6003], isUDPRequest: function(port) { for (var i = 0; i < this.PUBG_UDP_PORTS.length; i++) { if (port === this.PUBG_UDP_PORTS[i]) return "GAME_UDP"; } for (var j = 0; j < this.VOICE_UDP_PORTS.length; j++) { if (port === this.VOICE_UDP_PORTS[j]) return "VOICE_UDP"; } return false; }, getFastRoute: function(mode, port) { var candidates = []; for (var name in PROXY) { var p = PROXY[name]; if (p.udpFast && !ZOMBIE.isDead(name)) { candidates.push(name); } } // If no UDP-capable, fall back to diamond if (candidates.length === 0) { candidates = getBestProxies(0, null, 2); } return GUARD.buildChain(candidates, mode, { burst: true, tier: 0 }); } }; // ═══════════════════════════════════════════════════════════════════════ // 📡 CARRIER BONDING — Simultaneous Orange + Zain ★ NEW // ═══════════════════════════════════════════════════════════════════════ var BONDING = { activeBonds: {}, maxBondDuration: 300000, // 5 min createBond: function(mode) { var orange = getBestProxies(0, "ORANGE", 1)[0]; var zain = getBestProxies(0, "ZAIN", 1)[0]; if (!orange || !zain) return null; var bondId = "bond_" + now() + "_" + Math.random().toString(36).substr(2, 4); var bond = { id: bondId, orange: orange, zain: zain, created: now(), mode: mode, primary: orange, failover: zain, lastSwitch: 0, switchCooldown: 10000 }; this.activeBonds[bondId] = bond; return bondId; }, getRoute: function(bondId) { var bond = this.activeBonds[bondId]; if (!bond) return null; // Check if primary is healthy var primaryHealth = getHealthStatus(bond.primary); if (primaryHealth.status === "CRITICAL" || primaryHealth.status === "POOR") { if (now() - bond.lastSwitch > bond.switchCooldown) { // Switch to failover var temp = bond.primary; bond.primary = bond.failover; bond.failover = temp; bond.lastSwitch = now(); } } return GUARD.buildChain([bond.primary], bond.mode, { burst: true }); }, cleanup: function() { for (var id in this.activeBonds) { if (now() - this.activeBonds[id].created > this.maxBondDuration) { delete this.activeBonds[id]; } } } }; // ═══════════════════════════════════════════════════════════════════════ // 🔒 TLS FINGERPRINT DETECTION ★ NEW // ═══════════════════════════════════════════════════════════════════════ var TLS = { suspiciousPatterns: [ // Known anti-cheat TLS fingerprints "ja3_", "ja4_", "fingerprint", "tls_inspect", "mitm_detect", "certificate_pinning", "ssl_bump" ], isSuspicious: function(host) { if (!CFG.ENABLE_TLS_DETECTION) return false; var h = host.toLowerCase(); for (var i = 0; i < this.suspiciousPatterns.length; i++) { if (h.indexOf(this.suspiciousPatterns[i]) !== -1) { return true; } } return false; }, getSecureRoute: function(mode) { // Use shortest chain + Diamond only for suspicious TLS return GUARD.buildChain( ["ORANGE_LEGEND_1", "ORANGE_DIAMOND_1"], mode, { burst: true, tier: -1 } ); } }; // ═══════════════════════════════════════════════════════════════════════ // 🕸️ GRAPH-BASED ROUTE TOPOLOGY ★ NEW // ═══════════════════════════════════════════════════════════════════════ var GRAPH = { nodes: {}, edges: {}, adjacency: {}, build: function() { // Nodes = proxies for (var name in PROXY) { this.nodes[name] = { proxy: PROXY[name], health: HEALTH[name] || { score: 50 } }; } // Edges = compatible transitions between proxies var names = Object.keys(PROXY); for (var i = 0; i < names.length; i++) { this.adjacency[names[i]] = []; for (var j = 0; j < names.length; j++) { if (i === j) continue; var a = PROXY[names[i]]; var b = PROXY[names[j]]; // Edge weight = compatibility score var weight = this.edgeWeight(a, b); if (weight > 0) { this.adjacency[names[i]].push({ target: names[j], weight: weight }); } } } }, edgeWeight: function(a, b) { var w = 0; // Same carrier = lower weight (want diversity) if (a.carrier === b.carrier) w -= 10; else w += 20; // Similar tier = good if (Math.abs(a.tier - b.tier) <= 1) w += 15; // Both burst capable = great if (a.burstCapable && b.burstCapable) w += 25; return w; }, // Find best path of length N bestPath: function(start, length) { if (!this.adjacency[start]) return [start]; var path = [start]; var current = start; for (var i = 1; i < length; i++) { var neighbors = this.adjacency[current]; if (neighbors.length === 0) break; // Sort by weight descending neighbors.sort(function(a, b) { return b.weight - a.weight; }); // Pick best that's not already in path var chosen = null; for (var j = 0; j < neighbors.length; j++) { if (path.indexOf(neighbors[j].target) === -1) { chosen = neighbors[j].target; break; } } if (!chosen) break; path.push(chosen); current = chosen; } return path; } }; // ═══════════════════════════════════════════════════════════════════════ // 🧪 AUTO-CALIBRATION MODE ★ NEW // ═══════════════════════════════════════════════════════════════════════ var CALIBRATION = { active: false, phase: 0, results: [], startTime: 0, start: function() { if (!CFG.ENABLE_AUTO_CALIBRATION) return; if (SESSION.pubgRequests > 10) return; // Only at cold start this.active = true; this.phase = 0; this.results = []; this.startTime = now(); }, nextPhase: function() { if (!this.active) return null; var allNames = Object.keys(PROXY); var tierGroups = [[], [], [], [], []]; for (var i = 0; i < allNames.length; i++) { var p = PROXY[allNames[i]]; if (p && p.tier >= -1 && p.tier <= 4) { tierGroups[p.tier + 1].push(allNames[i]); } } if (this.phase < 5) { var group = tierGroups[this.phase]; this.phase++; return { proxies: group.slice(0, 3), duration: 15000, // 15s per tier test tier: this.phase - 1 }; } this.active = false; return this.getWinner(); }, record: function(tier, avgPing, successRate) { this.results.push({ tier: tier, avgPing: avgPing, successRate: successRate }); }, getWinner: function() { if (this.results.length === 0) return null; var best = this.results[0]; for (var i = 1; i < this.results.length; i++) { // Weighted score: ping 70%, success 30% var score = this.results[i].avgPing * -0.7 + this.results[i].successRate * 0.3; var bestScore = best.avgPing * -0.7 + best.successRate * 0.3; if (score > bestScore) best = this.results[i]; } return best; } }; // ═══════════════════════════════════════════════════════════════════════ // 📋 SESSION REPLAY & DEBUGGER ★ NEW // ═══════════════════════════════════════════════════════════════════════ var DEBUGGER = { log: [], maxLog: 200, enabled: CFG.ENABLE_DEBUGGER, record: function(event, data) { if (!this.enabled) return; var entry = { t: now(), event: event, data: data, sessionAge: SESSION.age(), ping: PING.current(), mode: SESSION.currentMode, state: SESSION.gameState }; this.log.push(entry); if (this.log.length > this.maxLog) { this.log.shift(); } }, replay: function(filter) { if (!filter) return this.log; var result = []; for (var i = 0; i < this.log.length; i++) { if (this.log[i].event === filter) { result.push(this.log[i]); } } return result; }, summary: function() { var events = {}; for (var i = 0; i < this.log.length; i++) { events[this.log[i].event] = (events[this.log[i].event] || 0) + 1; } return events; }, lastError: null, error: function(msg, data) { this.lastError = { t: now(), msg: msg, data: data }; this.record("ERROR", { msg: msg, data: data }); } }; // ═══════════════════════════════════════════════════════════════════════ // 📈 REAL-TIME HEATMAP ENGINE ★ NEW // ═══════════════════════════════════════════════════════════════════════ var HEATMAP = { cells: {}, gridSize: 16, // /16 network cells record: function(ip, quality, mode) { if (!CFG.ENABLE_HEATMAP) return; if (!ip || !isIPv4(ip)) return; var parts = ip.split("."); var cellKey = parts[0] + "." + parts[1] + ".0.0/16"; if (!this.cells[cellKey]) { this.cells[cellKey] = { samples: 0, totalQuality: 0, avgQuality: 0, bestMode: null, bestPing: 999 }; } var cell = this.cells[cellKey]; cell.samples++; cell.totalQuality += quality; cell.avgQuality = Math.round(cell.totalQuality / cell.samples); if (mode && MODES[mode]) { var ping = PING.modeAvg(mode, 3); if (ping < cell.bestPing) { cell.bestPing = ping; cell.bestMode = mode; } } }, getHotZones: function(count) { var zones = []; for (var key in this.cells) { zones.push({ network: key, avgQuality: this.cells[key].avgQuality, samples: this.cells[key].samples, bestPing: this.cells[key].bestPing }); } zones.sort(function(a, b) { return b.avgQuality - a.avgQuality; }); return zones.slice(0, count || 10); }, getColdZones: function(count) { var zones = this.getHotZones(999); zones.sort(function(a, b) { return a.avgQuality - b.avgQuality; }); return zones.slice(0, count || 5); } }; // ═══════════════════════════════════════════════════════════════════════ // 🔀 A/B ROUTE TESTING ENGINE ★ NEW // ════════════════════════════━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ var AB_TEST = { experiments: {}, activeExperiment: null, create: function(name, routeA, routeB, trafficSplit) { if (!CFG.ENABLE_AB_TESTING) return null; this.experiments[name] = { routeA: routeA, routeB: routeB, split: trafficSplit || 50, aSamples: 0, aTotalPing: 0, aSuccess: 0, bSamples: 0, bTotalPing: 0, bSuccess: 0, started: now() }; return name; }, route: function(name) { var exp = this.experiments[name]; if (!exp) return null; var useA = (Math.random() * 100) < exp.split; return useA ? exp.routeA : exp.routeB; }, record: function(name, route, ping, success) { var exp = this.experiments[name]; if (!exp) return; if (route === exp.routeA) { exp.aSamples++; exp.aTotalPing += ping; if (success) exp.aSuccess++; } else { exp.bSamples++; exp.bTotalPing += ping; if (success) exp.bSuccess++; } }, results: function(name) { var exp = this.experiments[name]; if (!exp) return null; return { routeA: { samples: exp.aSamples, avgPing: exp.aSamples > 0 ? Math.round(exp.aTotalPing / exp.aSamples) : 0, successRate: exp.aSamples > 0 ? Math.round((exp.aSuccess / exp.aSamples) * 100) : 0 }, routeB: { samples: exp.bSamples, avgPing: exp.bSamples > 0 ? Math.round(exp.bTotalPing / exp.bSamples) : 0, successRate: exp.bSamples > 0 ? Math.round((exp.bSuccess / exp.bSamples) * 100) : 0 }, winner: this.determineWinner(exp) }; }, determineWinner: function(exp) { if (exp.aSamples < 10 || exp.bSamples < 10) return "INSUFFICIENT"; var aScore = (exp.aSuccess / exp.aSamples) * 100 - (exp.aTotalPing / exp.aSamples) * 0.5; var bScore = (exp.bSuccess / exp.bSamples) * 100 - (exp.bTotalPing / exp.bSamples) * 0.5; if (Math.abs(aScore - bScore) < 5) return "TIE"; return aScore > bScore ? "A" : "B"; } }; // ═══════════════════════════════════════════════════════════════════════ // ENHANCED SESSION v40 // ═══════════════════════════════════════════════════════════════════════ var SESSION = { start: now(), sessionId: generateSessionId(), requests: 0, pubgRequests: 0, jordanHits: 0, foreignHits: 0, directHits: 0, blockedHits: 0, totalPingTime: 0, bestPing: 999, worstPing: 0, modeStats: {}, currentMode: null, lastModeChange: 0, gameState: "UNKNOWN", lastStateChange: 0, inGameTime: 0, lobbyTime: 0, networkQuality: "UNKNOWN", congestionLevel: 0, peakHours: false, weekend: false, patterns: {}, predictions: {}, // ★ NEW v40 fields squadSize: "UNKNOWN", // solo/duo/squad currentMap: "UNKNOWN", matchPhase: "NONE", // lobby/aircraft/drop/endgame voiceActive: false, calibrationDone: false, bondId: null, age: function() { return now() - this.start; }, isWarm: function() { return this.pubgRequests >= 5 && this.age() > 10000; }, jordanRatio: function() { var t = this.jordanHits + this.foreignHits; return t > 0 ? Math.round((this.jordanHits / t) * 100) : 0; },
